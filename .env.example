# ─────────────────────────────────────────────────────────────────────────────
#  Antigravity Autonomous Sales Pipeline — Environment Template
#  Copy this file to .env and fill in your credentials.
#  NEVER commit your .env file — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI Models (LLM API) ──────────────────────────────────────────────────────
# E.g. OpenAI, Anthropic, Groq, or Local API
LLM_API_KEY=your-llm-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_PRIMARY=gpt-4o-mini
LLM_MODEL_FALLBACK=gpt-4o

# ── Email (Gmail SMTP + IMAP) ─────────────────────────────────────────────────
# Use a Gmail App Password (NOT your account password).
# Enable 2FA, then: https://support.google.com/accounts/answer/185833
EMAIL_FROM=your-gmail@gmail.com
EMAIL_TO=your-receiving-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Your Identity (shown in email signatures) ─────────────────────────────────
SENDER_NAME=Your Name
SENDER_HANDLE=@your-social-handle

# ── GitHub (for demo site deployment) ────────────────────────────────────────
# Create a token at: https://github.com/settings/tokens
# Required scopes: repo (full control of private repositories)
GITHUB_TOKEN=ghp_your_token_here
GITHUB_USERNAME=your-github-username

# ── Vercel (optional — for live demo URLs) ────────────────────────────────────
# Create a token at: https://vercel.com/account/tokens
VERCEL_TOKEN=your-vercel-token-here

# ── Apify (optional — enhanced lead scraping) ─────────────────────────────────
# Get a free token at: https://apify.com
APIFY_TOKEN=your-apify-token-here

# ── Outreach Settings ────────────────────────────────────────────────────────
# Set SEND_OUTREACH_EMAILS=true to enable autonomous cold email sending.
# Start with false to review leads first.
SEND_OUTREACH_EMAILS=false
OUTREACH_MAX_PER_CYCLE=50
OUTREACH_SCORE_THRESHOLD=10
OUTREACH_PRICE=$1,500
